# Force LF line endings in the working tree on every platform, regardless of
# each contributor's core.autocrlf setting. Biome formats with LF, so a CRLF
# checkout (autocrlf=true on Windows) made `bun run lint` report a format error
# on every file. eol=lf keeps the working tree matching the LF-normalized repo.
* text=auto eol=lf

# Binary files must never be normalized.
*.lockb binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
